# windy-registry production env. Copy to deploy/.env.production and fill in.
# All values flow into pydantic-settings (case-insensitive); see
# src/windy_registry/config.py.

# --- Identity (also injected by deploy workflow as build args) ---
ENVIRONMENT=production
# COMMIT_SHA + BUILD_TIMESTAMP are set by the deploy pipeline, not here.

# --- Database (WD-14) ---
DATABASE_URL=postgresql+asyncpg://windyregistry:CHANGE_ME@postgres:5432/windyregistry
REDIS_URL=redis://redis:6379/0

# --- R2 (WD-13) ---
R2_ACCOUNT_ID=193b347aedeaafe35de0b5a534b2d9aa
R2_BUCKET=windydrops-bundles
R2_PUBLIC_DOMAIN=drops.windydrops.com
# Lockup these from ~/kit-army-config/ACCESS_LOCKBOX.md
# §"R2 Distribution Buckets — Windy Desktop App Releases"
# (the windycloud-userdata "Apply to all buckets" keypair works for windydrops-bundles too).
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# --- JWKS (WD-15 dual-JWKS auth) ---
PRO_JWKS_URL=https://account.windyword.ai/.well-known/jwks.json
ETERNITAS_JWKS_URL=https://api.eternitas.ai/.well-known/eternitas-keys

# --- Stripe (WD-27 + WD-28) ---
# Lockup from lockbox section "Stripe Connect" once issued.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
